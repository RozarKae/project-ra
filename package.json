{
  "name": "project-ra",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:invitation",
    "dev:invitation": "npm run dev --workspace=apps/invitation",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "build:invitation": "npm run build --workspace=apps/invitation",
    "build:admin": "npm run build --workspace=apps/admin",
    "build": "npm run build:invitation && npm run build:admin && node scripts/bundle-dist.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@tanstack/react-query": "^5.56.2",
    "firebase": "^10.13.2",
    "framer-motion": "^11.5.4",
    "lucide-react": "^0.439.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.53.0",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.26.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.45",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.3",
    "vite": "^5.4.2"
  }
}
